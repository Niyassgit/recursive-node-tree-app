{
   "compilerOptions": {
    "target": "ES2020",
    "module": "node16",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "moduleResolution": "node16",
    "allowArbitraryExtensions": true
  },
  "include": ["src"],
  "exclude": ["node_modules","eslint.config.ts"]
}